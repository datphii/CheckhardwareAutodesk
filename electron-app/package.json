{
  "name": "autodesk-hwscanner-desktop",
  "version": "0.1.0",
  "private": true,
  "author": "Autodesk HWScanner",
  "description": "Electron React desktop app for Autodesk hardware and licensing connectivity checks.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron:dev": "cross-env NODE_ENV=development concurrently -k \"npm:dev\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder --win nsis portable",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "typescript": "^5.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.468.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.autodesk.hwscanner",
    "productName": "Autodesk Hardware Scanner",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../scanner/rules",
        "to": "config/rules"
      },
      {
        "from": "../scanner/network_endpoints",
        "to": "config/network_endpoints"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    }
  }
}
